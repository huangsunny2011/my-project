# 自動檢測文本文件並進行標準化
* text=auto

# 明確指定文本文件
*.md text
*.txt text
*.json text
*.xml text
*.yaml text
*.yml text

# 源代碼文件
*.js text
*.ts text
*.jsx text
*.tsx text
*.css text
*.scss text
*.html text
*.py text
*.java text
*.c text
*.cpp text
*.h text
*.hpp text

# PowerShell 腳本使用 CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell 腳本使用 LF
*.sh text eol=lf

# 二進制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary
*.pdf binary
